<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>About Us — World Youth Council</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=DM+Serif+Display:ital@0;1&family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;0,9..40,600;1,9..40,300&display=swap" rel="stylesheet" />

  <style>
    /* ── Reset & Variables ─────────────────────────────────────────── */
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --blue:    #0B2A4A;
      --gray:    #F5F5F5;
      --accent:  #3B82F6;
      --white:   #ffffff;
      --text:    #1a1a2e;
      --muted:   #6b7280;
      --border:  #e5e7eb;
      --serif:   'DM Serif Display', Georgia, serif;
      --sans:    'DM Sans', system-ui, sans-serif;
      --max:     1200px;
      --nav-h:   72px;
    }

    html { scroll-behavior: smooth; }

    body {
      font-family: var(--sans);
      background: var(--white);
      color: var(--text);
      line-height: 1.6;
      -webkit-font-smoothing: antialiased;
    }

    /* ── Navbar ────────────────────────────────────────────────────── */
    nav {
      position: fixed;
      top: 0; left: 0; right: 0;
      z-index: 100;
      height: var(--nav-h);
      display: flex;
      align-items: center;
      padding: 0 clamp(1.25rem, 4vw, 3rem);
      background: rgba(255,255,255,0.95);
      backdrop-filter: blur(12px);
      border-bottom: 1px solid var(--border);
      transition: box-shadow .3s;
    }
    nav.scrolled { box-shadow: 0 2px 20px rgba(11,42,74,.07); }

    .nav-inner {
      width: 100%;
      max-width: var(--max);
      margin: 0 auto;
      display: flex;
      align-items: center;
      justify-content: space-between;
    }

    .logo {
      font-family: var(--serif);
      font-size: 1.15rem;
      color: var(--blue);
      text-decoration: none;
      letter-spacing: .01em;
    }
    .logo span { color: var(--accent); }

    .nav-links {
      display: flex;
      align-items: center;
      gap: clamp(1.25rem, 2.5vw, 2.25rem);
      list-style: none;
    }
    .nav-links a {
      font-size: .875rem;
      font-weight: 500;
      color: var(--blue);
      text-decoration: none;
      letter-spacing: .02em;
      opacity: .75;
      transition: opacity .2s;
    }
    .nav-links a:hover, .nav-links a.active { opacity: 1; }
    .nav-links a.active { border-bottom: 2px solid var(--accent); padding-bottom: 2px; }

    .nav-cta {
      background: var(--blue);
      color: var(--white) !important;
      opacity: 1 !important;
      padding: .45rem 1.1rem !important;
      border-radius: 6px;
      font-size: .8rem !important;
      letter-spacing: .04em !important;
      text-transform: uppercase;
      transition: background .2s !important;
    }
    .nav-cta:hover { background: var(--accent) !important; }

    /* hamburger */
    .burger { display: none; flex-direction: column; gap: 5px; cursor: pointer; border: none; background: none; padding: 4px; }
    .burger span { display: block; width: 22px; height: 2px; background: var(--blue); border-radius: 2px; transition: .3s; }
    .burger.open span:nth-child(1) { transform: translateY(7px) rotate(45deg); }
    .burger.open span:nth-child(2) { opacity: 0; }
    .burger.open span:nth-child(3) { transform: translateY(-7px) rotate(-45deg); }

    .mobile-menu {
      display: none;
      position: fixed;
      inset: var(--nav-h) 0 0 0;
      background: var(--white);
      z-index: 99;
      flex-direction: column;
      padding: 2rem clamp(1.25rem, 5vw, 3rem);
      gap: 1.5rem;
      border-top: 1px solid var(--border);
    }
    .mobile-menu.open { display: flex; }
    .mobile-menu a { font-size: 1.1rem; font-weight: 500; color: var(--blue); text-decoration: none; }

    @media (max-width: 768px) {
      .nav-links { display: none; }
      .burger { display: flex; }
    }

    /* ── Page wrapper ──────────────────────────────────────────────── */
    main { padding-top: var(--nav-h); }

    /* ── Hero ──────────────────────────────────────────────────────── */
    .about-hero {
      position: relative;
      background: var(--blue);
      color: var(--white);
      overflow: hidden;
      padding: clamp(5rem, 12vw, 9rem) clamp(1.25rem, 5vw, 3rem) clamp(4rem, 9vw, 7rem);
    }

    /* subtle grid texture */
    .about-hero::before {
      content: '';
      position: absolute;
      inset: 0;
      background-image:
        linear-gradient(rgba(59,130,246,.07) 1px, transparent 1px),
        linear-gradient(90deg, rgba(59,130,246,.07) 1px, transparent 1px);
      background-size: 60px 60px;
      pointer-events: none;
    }

    .hero-inner {
      max-width: var(--max);
      margin: 0 auto;
      position: relative;
    }

    .hero-eyebrow {
      display: inline-flex;
      align-items: center;
      gap: .5rem;
      font-size: .75rem;
      font-weight: 600;
      letter-spacing: .14em;
      text-transform: uppercase;
      color: var(--accent);
      margin-bottom: 1.5rem;
    }
    .hero-eyebrow::before {
      content: '';
      display: block;
      width: 28px; height: 1px;
      background: var(--accent);
    }

    .about-hero h1 {
      font-family: var(--serif);
      font-size: clamp(2.75rem, 6vw, 5rem);
      line-height: 1.08;
      max-width: 16ch;
      margin-bottom: 1.75rem;
    }

    .about-hero p {
      font-size: clamp(1rem, 2vw, 1.175rem);
      font-weight: 300;
      line-height: 1.75;
      max-width: 54ch;
      opacity: .8;
    }

    /* decorative circle */
    .hero-orb {
      position: absolute;
      right: -6rem;
      top: 50%;
      transform: translateY(-50%);
      width: clamp(280px, 38vw, 520px);
      aspect-ratio: 1;
      border-radius: 50%;
      border: 1px solid rgba(59,130,246,.2);
      pointer-events: none;
    }
    .hero-orb::before {
      content: '';
      position: absolute;
      inset: 2rem;
      border-radius: 50%;
      border: 1px solid rgba(59,130,246,.12);
    }

    /* ── Section utility ───────────────────────────────────────────── */
    .section {
      padding: clamp(4rem, 9vw, 7rem) clamp(1.25rem, 5vw, 3rem);
    }
    .section-inner {
      max-width: var(--max);
      margin: 0 auto;
    }

    .section-label {
      display: inline-flex;
      align-items: center;
      gap: .5rem;
      font-size: .7rem;
      font-weight: 600;
      letter-spacing: .15em;
      text-transform: uppercase;
      color: var(--accent);
      margin-bottom: 1rem;
    }
    .section-label::before {
      content: '';
      display: block;
      width: 22px; height: 1px;
      background: var(--accent);
    }

    /* ── Mission strip ─────────────────────────────────────────────── */
    .mission-section { background: var(--gray); }

    .mission-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: clamp(2rem, 5vw, 5rem);
      align-items: start;
    }

    .mission-left h2 {
      font-family: var(--serif);
      font-size: clamp(2rem, 4vw, 3rem);
      line-height: 1.15;
      color: var(--blue);
      margin-bottom: 1.5rem;
    }

    .mission-right p {
      font-size: 1rem;
      line-height: 1.8;
      color: #374151;
      margin-bottom: 1.25rem;
    }

    .stat-row {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 1.5rem;
      margin-top: 3rem;
      padding-top: 3rem;
      border-top: 1px solid var(--border);
    }
    .stat-item {}
    .stat-num {
      font-family: var(--serif);
      font-size: clamp(2rem, 3.5vw, 2.75rem);
      color: var(--blue);
      display: block;
      line-height: 1;
    }
    .stat-label {
      font-size: .8rem;
      font-weight: 500;
      letter-spacing: .06em;
      text-transform: uppercase;
      color: var(--muted);
      margin-top: .5rem;
    }

    @media (max-width: 700px) {
      .mission-grid { grid-template-columns: 1fr; }
      .stat-row { grid-template-columns: 1fr 1fr; }
    }

    /* ── Values ────────────────────────────────────────────────────── */
    .values-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 1.5px;
      background: var(--border);
      border: 1.5px solid var(--border);
      border-radius: 12px;
      overflow: hidden;
      margin-top: 3rem;
    }

    .value-card {
      background: var(--white);
      padding: 2.25rem 2rem;
      transition: background .2s;
    }
    .value-card:hover { background: #fafbff; }

    .value-icon {
      width: 40px; height: 40px;
      border-radius: 8px;
      background: rgba(59,130,246,.1);
      display: flex; align-items: center; justify-content: center;
      margin-bottom: 1.25rem;
    }
    .value-icon svg { width: 20px; height: 20px; stroke: var(--accent); fill: none; stroke-width: 1.75; }

    .value-card h3 {
      font-family: var(--serif);
      font-size: 1.2rem;
      color: var(--blue);
      margin-bottom: .6rem;
    }
    .value-card p {
      font-size: .875rem;
      line-height: 1.7;
      color: var(--muted);
    }

    @media (max-width: 768px) {
      .values-grid { grid-template-columns: 1fr; }
    }

    /* ── Founders ──────────────────────────────────────────────────── */
    .founders-section { background: var(--white); }

    .founders-intro {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: clamp(2rem, 5vw, 5rem);
      align-items: end;
      margin-bottom: clamp(3rem, 6vw, 5rem);
    }
    .founders-intro h2 {
      font-family: var(--serif);
      font-size: clamp(2rem, 4vw, 3rem);
      line-height: 1.15;
      color: var(--blue);
    }
    .founders-intro p {
      font-size: 1rem;
      line-height: 1.8;
      color: #374151;
      align-self: end;
    }

    @media (max-width: 700px) {
      .founders-intro { grid-template-columns: 1fr; }
    }

    /* founder card */
    .founders-cards {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: clamp(1.5rem, 3vw, 2.5rem);
    }

    @media (max-width: 750px) {
      .founders-cards { grid-template-columns: 1fr; }
    }

    .founder-card {
      border: 1.5px solid var(--border);
      border-radius: 16px;
      overflow: hidden;
      transition: box-shadow .3s;
    }
    .founder-card:hover { box-shadow: 0 12px 40px rgba(11,42,74,.08); }

    /* image placeholder */
    .founder-photo {
      width: 100%;
      aspect-ratio: 4 / 3;
      background: var(--gray);
      position: relative;
      display: flex;
      align-items: center;
      justify-content: center;
      overflow: hidden;
    }
    .founder-photo img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      display: block;
    }
    .founder-photo-placeholder {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: .75rem;
      color: #9ca3af;
    }
    .founder-photo-placeholder svg { width: 48px; height: 48px; opacity: .4; }
    .founder-photo-placeholder span {
      font-size: .75rem;
      font-weight: 500;
      letter-spacing: .08em;
      text-transform: uppercase;
    }

    .photo-label {
      position: absolute;
      bottom: 1rem; left: 1rem;
      background: rgba(255,255,255,.92);
      backdrop-filter: blur(6px);
      border-radius: 6px;
      padding: .3rem .75rem;
      font-size: .7rem;
      font-weight: 600;
      letter-spacing: .1em;
      text-transform: uppercase;
      color: var(--blue);
      border: 1px solid var(--border);
    }

    .founder-body { padding: 1.75rem 2rem 2rem; }

    .founder-role {
      font-size: .7rem;
      font-weight: 600;
      letter-spacing: .14em;
      text-transform: uppercase;
      color: var(--accent);
      margin-bottom: .5rem;
    }

    .founder-name {
      font-family: var(--serif);
      font-size: 1.45rem;
      color: var(--blue);
      margin-bottom: 1.25rem;
    }

    /* editable message */
    .founder-message-label {
      font-size: .7rem;
      font-weight: 600;
      letter-spacing: .1em;
      text-transform: uppercase;
      color: var(--muted);
      margin-bottom: .5rem;
      display: block;
    }

    .founder-message {
      width: 100%;
      min-height: 130px;
      padding: 1rem 1.1rem;
      border: 1.5px solid var(--border);
      border-radius: 10px;
      font-family: var(--sans);
      font-size: .925rem;
      line-height: 1.7;
      color: var(--text);
      background: var(--gray);
      resize: vertical;
      outline: none;
      transition: border-color .2s, background .2s;
    }
    .founder-message::placeholder { color: #b0b7c3; }
    .founder-message:focus {
      border-color: var(--accent);
      background: var(--white);
      box-shadow: 0 0 0 3px rgba(59,130,246,.08);
    }

    /* ── Story timeline ────────────────────────────────────────────── */
    .story-section { background: var(--blue); color: var(--white); }
    .story-section .section-label { color: rgba(59,130,246,.8); }
    .story-section .section-label::before { background: rgba(59,130,246,.8); }

    .story-header {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: clamp(2rem, 5vw, 5rem);
      align-items: end;
      margin-bottom: clamp(3rem, 6vw, 5rem);
    }
    .story-header h2 {
      font-family: var(--serif);
      font-size: clamp(2rem, 4vw, 3rem);
      line-height: 1.15;
    }
    .story-header p {
      font-size: 1rem;
      line-height: 1.8;
      opacity: .75;
    }
    @media (max-width: 700px) {
      .story-header { grid-template-columns: 1fr; }
    }

    .timeline {
      position: relative;
      padding-left: 2rem;
    }
    .timeline::before {
      content: '';
      position: absolute;
      left: 0;
      top: 6px;
      bottom: 0;
      width: 1px;
      background: rgba(255,255,255,.15);
    }

    .timeline-item {
      position: relative;
      padding: 0 0 3rem 2.25rem;
    }
    .timeline-item:last-child { padding-bottom: 0; }

    .timeline-dot {
      position: absolute;
      left: -5px;
      top: 6px;
      width: 11px; height: 11px;
      border-radius: 50%;
      background: var(--accent);
      border: 2px solid var(--blue);
    }

    .timeline-year {
      font-size: .7rem;
      font-weight: 700;
      letter-spacing: .14em;
      text-transform: uppercase;
      color: var(--accent);
      margin-bottom: .4rem;
    }

    .timeline-item h3 {
      font-family: var(--serif);
      font-size: 1.3rem;
      margin-bottom: .5rem;
    }
    .timeline-item p {
      font-size: .9rem;
      line-height: 1.75;
      opacity: .7;
      max-width: 55ch;
    }

    /* ── Global reach ──────────────────────────────────────────────── */
    .reach-section { background: var(--gray); }

    .reach-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: clamp(2rem, 5vw, 5rem);
      align-items: center;
      margin-top: 3rem;
    }

    .reach-left h2 {
      font-family: var(--serif);
      font-size: clamp(2rem, 4vw, 3rem);
      line-height: 1.15;
      color: var(--blue);
      margin-bottom: 1.5rem;
    }
    .reach-left p {
      font-size: 1rem;
      line-height: 1.8;
      color: #374151;
      margin-bottom: 1rem;
    }

    .reach-regions {
      display: flex;
      flex-direction: column;
      gap: .75rem;
    }

    .region-row {
      display: flex;
      align-items: center;
      gap: 1rem;
    }
    .region-name {
      font-size: .8rem;
      font-weight: 600;
      letter-spacing: .06em;
      text-transform: uppercase;
      color: var(--blue);
      width: 130px;
      flex-shrink: 0;
    }
    .region-bar-bg {
      flex: 1;
      height: 4px;
      background: var(--border);
      border-radius: 99px;
      overflow: hidden;
    }
    .region-bar {
      height: 100%;
      background: var(--accent);
      border-radius: 99px;
      transform-origin: left;
      transform: scaleX(0);
      transition: transform 1s cubic-bezier(.22,1,.36,1);
    }
    .region-bar.animated { transform: scaleX(1); }
    .region-count {
      font-size: .8rem;
      font-weight: 500;
      color: var(--muted);
      width: 40px;
      text-align: right;
    }

    @media (max-width: 700px) {
      .reach-grid { grid-template-columns: 1fr; }
    }

    /* placeholder map */
    .map-placeholder {
      background: var(--white);
      border: 1.5px solid var(--border);
      border-radius: 16px;
      aspect-ratio: 4 / 3;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      gap: 1rem;
      color: #9ca3af;
      position: relative;
      overflow: hidden;
    }
    .map-placeholder svg { width: 64px; height: 64px; opacity: .2; }
    .map-placeholder span {
      font-size: .75rem;
      font-weight: 600;
      letter-spacing: .12em;
      text-transform: uppercase;
    }

    /* ── CTA banner ────────────────────────────────────────────────── */
    .cta-section {
      background: var(--white);
      text-align: center;
      padding: clamp(4rem, 9vw, 7rem) clamp(1.25rem, 5vw, 3rem);
      border-top: 1.5px solid var(--border);
    }
    .cta-section h2 {
      font-family: var(--serif);
      font-size: clamp(1.75rem, 4vw, 2.75rem);
      color: var(--blue);
      margin-bottom: 1rem;
    }
    .cta-section p {
      font-size: 1rem;
      color: var(--muted);
      max-width: 50ch;
      margin: 0 auto 2rem;
      line-height: 1.75;
    }
    .btn-group { display: flex; gap: 1rem; justify-content: center; flex-wrap: wrap; }
    .btn-primary {
      display: inline-block;
      background: var(--blue);
      color: var(--white);
      padding: .8rem 2rem;
      border-radius: 8px;
      font-size: .875rem;
      font-weight: 600;
      letter-spacing: .04em;
      text-decoration: none;
      transition: background .2s, transform .15s;
    }
    .btn-primary:hover { background: var(--accent); transform: translateY(-1px); }
    .btn-outline {
      display: inline-block;
      border: 1.5px solid var(--blue);
      color: var(--blue);
      padding: .8rem 2rem;
      border-radius: 8px;
      font-size: .875rem;
      font-weight: 600;
      letter-spacing: .04em;
      text-decoration: none;
      transition: border-color .2s, color .2s, transform .15s;
    }
    .btn-outline:hover { border-color: var(--accent); color: var(--accent); transform: translateY(-1px); }

    /* ── Footer ────────────────────────────────────────────────────── */
    footer {
      background: var(--blue);
      color: rgba(255,255,255,.65);
      padding: clamp(3rem, 6vw, 5rem) clamp(1.25rem, 5vw, 3rem) 2rem;
    }
    .footer-inner {
      max-width: var(--max);
      margin: 0 auto;
    }
    .footer-top {
      display: grid;
      grid-template-columns: 1.6fr 1fr 1fr 1fr;
      gap: 3rem;
      padding-bottom: 3rem;
      border-bottom: 1px solid rgba(255,255,255,.1);
    }
    .footer-brand .logo { display: inline-block; margin-bottom: 1rem; color: var(--white); }
    .footer-brand p { font-size: .85rem; line-height: 1.75; }
    .footer-col h4 {
      font-size: .7rem;
      font-weight: 700;
      letter-spacing: .14em;
      text-transform: uppercase;
      color: var(--white);
      margin-bottom: 1.25rem;
    }
    .footer-col ul { list-style: none; display: flex; flex-direction: column; gap: .6rem; }
    .footer-col a { font-size: .85rem; color: rgba(255,255,255,.55); text-decoration: none; transition: color .2s; }
    .footer-col a:hover { color: var(--white); }
    .footer-bottom {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding-top: 2rem;
      font-size: .8rem;
      gap: 1rem;
      flex-wrap: wrap;
    }
    @media (max-width: 768px) {
      .footer-top { grid-template-columns: 1fr 1fr; }
    }
    @media (max-width: 480px) {
      .footer-top { grid-template-columns: 1fr; }
    }

    /* ── Dev Banner ────────────────────────────────────────────────── */
    .dev-banner {
      position: relative;
      z-index: 101;
      background: var(--blue);
      padding: .6rem clamp(1.25rem, 5vw, 3rem);
      display: flex;
      align-items: center;
      justify-content: center;
      gap: .75rem;
      font-size: .72rem;
      font-weight: 500;
      letter-spacing: .06em;
      color: rgba(255,255,255,.7);
      text-align: center;
    }
    .dev-banner strong { color: white; font-weight: 700; letter-spacing: .08em; }
    .dev-banner-dot {
      width: 6px; height: 6px;
      border-radius: 50%;
      background: #FBBF24;
      display: inline-block;
      animation: blinkDot 1.8s ease-in-out infinite;
      flex-shrink: 0;
    }
    @keyframes blinkDot { 0%, 100% { opacity: .4; } 50% { opacity: 1; } }

    /* ── Coming-Soon overlay (reach section) ───────────────────────── */
    .reach-coming-wrapper {
      position: relative;
    }
    .reach-coming-overlay {
      position: absolute;
      inset: -2rem;
      z-index: 2;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      gap: 1rem;
      background: rgba(245,245,245,.85);
      backdrop-filter: blur(7px);
      border-radius: 14px;
    }
    .reach-overlay-badge {
      display: inline-flex;
      align-items: center;
      gap: .5rem;
